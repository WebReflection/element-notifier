{
  "name": "element-notifier",
  "version": "2.0.2",
  "description": "A MutationObserver dis/connected helper",
  "main": "./esm/index.js",
  "module": "./esm/index.js",
  "types": "./esm/index.d.ts",
  "scripts": {
    "build": "npm run rollup:esm && npm run build:types && npm run size",
    "build:types": "tsc -p tsconfig.json",
    "rollup:esm": "rollup --config rollup/esm.config.js",
    "size": "cat esm.js | brotli | wc -c"
  },
  "keywords": [
    "mutation",
    "observer",
    "element"
  ],
  "files": [
    "esm/",
    "esm.js",
    "README.md",
    "LICENSE"
  ],
  "author": "Andrea Giammarchi",
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "rollup": "^4.60.2",
    "typescript": "^6.0.3"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./esm/index.d.ts",
      "import": "./esm/index.js"
    },
    "./esm": {
      "types": "./esm/index.d.ts",
      "import": "./esm.js"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WebReflection/element-notifier.git"
  },
  "bugs": {
    "url": "https://github.com/WebReflection/element-notifier/issues"
  },
  "homepage": "https://github.com/WebReflection/element-notifier#readme"
}
